
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended user information including roles and skill levels.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["Admin", "Technician", "Trainee"] },
        "skillLevel": { "type": "string", "enum": ["Beginner", "Intermediate", "Expert"] },
        "totalHours": { "type": "number" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Machine": {
      "title": "Machine",
      "description": "Equipment telemetry and status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "centerId": { "type": "string" },
        "status": { "type": "string", "enum": ["Available", "In Use", "Under Maintenance"] },
        "usageHours": { "type": "number" },
        "healthScore": { "type": "number" },
        "temperature": { "type": "number" },
        "vibration": { "type": "number" },
        "lastMaintenance": { "type": "string" }
      }
    },
    "Booking": {
      "title": "Booking",
      "description": "Machine reservation data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "centerId": { "type": "string" },
        "timeSlot": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "object" }
      }
    },
    "UsageLog": {
      "title": "Usage Log",
      "description": "Historical record of machine usage sessions and telemetry updates.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineId": { "type": "string" },
        "machineName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "duration": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "object" }
      }
    },
    "MaintenanceTicket": {
      "title": "Maintenance Ticket",
      "description": "A record of a maintenance issue for a machine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "machineId": { "type": "string" },
        "issue": { "type": "string" },
        "priority": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "assignedTechnician": { "type": "string" },
        "status": { "type": "string", "enum": ["Open", "In Progress", "Resolved"] },
        "createdAt": { "type": "object" }
      },
      "required": ["machineId", "issue", "priority", "status"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/entities/UserProfile",
      "description": "User profile data."
    },
    "/machines/{machineId}": {
      "schema": "#/entities/Machine",
      "description": "Fleet inventory data."
    },
    "/bookings/{bookingId}": {
      "schema": "#/entities/Booking",
      "description": "Training reservations."
    },
    "/usageLogs/{logId}": {
      "schema": "#/entities/UsageLog",
      "description": "Machine usage history and telemetry audit logs."
    },
    "/maintenanceTickets/{ticketId}": {
      "schema": "#/entities/MaintenanceTicket",
      "description": "Maintenance work orders."
    }
  }
}
